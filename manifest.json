{
  "manifest_version": 3,
  "name": "Response Data Extractor",
  "version": "1.0.0",
  "description": "Extract specific data from network responses based on URL pattern and data path",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
